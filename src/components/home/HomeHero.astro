---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import { getPostUrlBySlugAndLang } from "../../utils/url-utils";

interface Props {
	featuredPosts: CollectionEntry<"posts">[];
}

const { featuredPosts } = Astro.props;
const primaryPost = featuredPosts[0];
const secondaryPosts = featuredPosts.slice(1, 3);

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat("zh-CN", {
		year: "numeric",
		month: "numeric",
		day: "numeric",
	}).format(date);
---

<section class="home-shell">
	{primaryPost ? (
		<div class="featured-grid" aria-label="文章">
			<a href={getPostUrlBySlugAndLang(primaryPost.slug, "zh-CN")} class="featured-primary">
				<div class="post-badges">
					{primaryPost.data.pinned && <span>置顶</span>}
					{primaryPost.data.tags?.[0] && <span>{primaryPost.data.tags[0]}</span>}
				</div>
				<time datetime={primaryPost.data.published.toISOString()}>
					{formatDate(primaryPost.data.published)}
				</time>
				<h2>{primaryPost.data.title}</h2>
				<p>{primaryPost.data.description}</p>
				<div class="post-footer">
					<span>阅读全文</span>
					<Icon name="material-symbols:arrow-forward-rounded" />
				</div>
			</a>

			<div class="featured-secondary">
				{secondaryPosts.map((post) => (
					<a href={getPostUrlBySlugAndLang(post.slug, "zh-CN")}>
						<time datetime={post.data.published.toISOString()}>
							{formatDate(post.data.published)}
						</time>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
					</a>
				))}
			</div>
		</div>
	) : (
		<p class="home-empty">暂无文章</p>
	)}
</section>

<style>
	.home-shell {
		min-height: calc(100vh - 12rem);
		padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 2vw, 1.5rem) 4rem;
		color: #303133;
	}

	:global(body.site-home) {
		background:
			radial-gradient(circle at 78% 18%, rgba(127, 168, 170, 0.08), transparent 28rem),
			linear-gradient(180deg, #f8f5ef 0%, #f4f7f6 55%, #f8f5ef 100%);
	}

	.home-empty {
		margin: 4rem 0;
		color: #8a8d91;
		text-align: center;
	}

	.featured-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(16rem, 20rem);
		gap: 1.5rem;
	}

	.featured-primary,
	.featured-secondary a {
		position: relative;
		display: block;
		border: 1px solid rgba(48, 49, 51, 0.07);
		border-radius: 1.65rem;
		background: rgba(255, 255, 255, 0.78);
		box-shadow: 0 18px 50px rgba(59, 50, 42, 0.07);
		backdrop-filter: blur(16px);
		color: inherit;
		text-decoration: none;
		transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
	}

	.featured-primary {
		min-height: 15rem;
		padding: clamp(1.6rem, 3vw, 2.2rem);
	}

	.featured-primary:hover,
	.featured-secondary a:hover {
		border-color: rgba(127, 168, 170, 0.28);
		box-shadow: 0 22px 60px rgba(59, 50, 42, 0.1);
		transform: translateY(-3px);
	}

	.post-badges {
		display: flex;
		gap: 0.55rem;
		margin-bottom: 1.35rem;
	}

	.post-badges span {
		padding: 0.35rem 0.65rem;
		border-radius: 0.45rem;
		background: rgba(127, 168, 170, 0.14);
		color: #6f9da0;
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	time {
		color: #a3a6aa;
		font-size: 0.82rem;
		font-weight: 700;
	}

	.featured-primary time {
		position: absolute;
		top: 1.8rem;
		right: 2rem;
	}

	.featured-primary h2,
	.featured-secondary h3 {
		margin: 0.65rem 0 0.9rem;
		color: #303133;
		font-weight: 800;
		line-height: 1.35;
	}

	.featured-primary h2 {
		max-width: 44rem;
		font-size: clamp(1.7rem, 3vw, 2.45rem);
	}

	.featured-primary p,
	.featured-secondary p {
		color: #777b80;
		line-height: 1.8;
	}

	.featured-primary p {
		max-width: 54rem;
		margin: 0;
		font-size: 1rem;
	}

	.post-footer {
		display: inline-flex;
		gap: 0.4rem;
		align-items: center;
		margin-top: 2rem;
		color: #6f9da0;
		font-weight: 800;
	}

	.featured-secondary {
		display: grid;
		gap: 1rem;
	}

	.featured-secondary a {
		padding: 1.25rem;
	}

	.featured-secondary h3 {
		font-size: 1.08rem;
	}

	.featured-secondary p {
		display: -webkit-box;
		margin: 0;
		overflow: hidden;
		font-size: 0.9rem;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	:global(html.dark) .home-shell {
		color: #ededec;
	}

	:global(html.dark) .featured-primary h2,
	:global(html.dark) .featured-secondary h3 {
		color: #f2f0ed;
	}

	:global(html.dark) .featured-primary p,
	:global(html.dark) .featured-secondary p {
		color: rgba(242, 240, 237, 0.68);
	}

	:global(html.dark) .featured-primary,
	:global(html.dark) .featured-secondary a {
		border-color: rgba(255, 255, 255, 0.08);
		background: rgba(31, 34, 35, 0.78);
		box-shadow: none;
	}

	@media (max-width: 900px) {
		.featured-grid {
			grid-template-columns: 1fr;
		}

		.featured-primary time {
			position: static;
		}
	}

	@media (max-width: 640px) {
		.home-shell {
			padding: 1.5rem 1rem 3rem;
		}

		.featured-primary,
		.featured-secondary a {
			border-radius: 1.35rem;
		}
	}
</style>
